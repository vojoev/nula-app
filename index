<!DOCTYPE html>
<html lang="sr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nulla — finansije</title>
<style>
  :root{
    --bg: #F6F7F9;
    --card: #FFFFFF;
    --ink: #16202A;
    --muted: #6B7785;
    --line: #E4E8ED;
    --accent: #146C5B;
    --accent-light: #E4F3EE;
    --danger: #B3432B;
    --danger-light: #FBEBE6;
    --gold: #B68B2E;
    --gold-light: #FAF3E3;
    --radius: 14px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  *{ box-sizing: border-box; margin:0; padding:0; }

  body{
    background: var(--bg);
    color: var(--ink);
    padding: 24px 16px 80px;
    -webkit-font-smoothing: antialiased;
  }

  .wrap{
    max-width: 760px;
    margin: 0 auto;
  }

  header{
    margin-bottom: 20px;
  }

  header h1{
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  header h1 .dot{
    color: var(--accent);
  }

  header p{
    color: var(--muted);
    font-size: 13px;
    margin-top: 4px;
  }

  /* Tabs */
  .tabs{
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .tab{
    background: transparent;
    border: none;
    padding: 10px 4px;
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s ease;
  }

  .tab.active{
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  .view{ display: none; }
  .view.active{ display: block; }

  /* Summary */
  .summary{
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 20px;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 560px){
    .summary{ grid-template-columns: 1fr; }
  }

  .summary .stat .label{
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  .summary .stat .value{
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .summary .stat.total .value{ color: var(--danger); }
  .summary .stat.paid .value{ color: var(--accent); }
  .summary .stat.savings .value{ color: var(--gold); }

  .progress-row{
    grid-column: 1 / -1;
    margin-top: 8px;
  }

  .progress-bar{
    height: 8px;
    background: var(--line);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-bar .fill{
    height: 100%;
    background: var(--accent);
    border-radius: 999px;
    transition: width 0.4s ease;
  }

  .progress-bar .fill.gold{ background: var(--gold); }

  .progress-row .pct{
    font-size: 12px;
    color: var(--muted);
    margin-top: 6px;
    text-align: right;
  }

  /* Add new */
  .add-card{
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 20px;
  }

  .add-card h2{
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 14px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .add-form{
    display: grid;
    grid-template-columns: 2fr 1fr auto;
    gap: 10px;
  }

  @media (max-width: 560px){
    .add-form{ grid-template-columns: 1fr; }
  }

  input{
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 11px 12px;
    font-size: 14px;
    font-family: inherit;
    color: var(--ink);
    background: var(--bg);
    outline: none;
    width: 100%;
  }

  input:focus{
    border-color: var(--accent);
    background: #fff;
  }

  button{
    border: none;
    border-radius: 10px;
    padding: 11px 18px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  button:hover{ opacity: 0.85; }

  .btn-primary{
    background: var(--accent);
    color: #fff;
  }

  .btn-gold{
    background: var(--gold);
    color: #fff;
  }

  /* Card list */
  .items{
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .item-card{
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px 20px;
  }

  .item-card.settled{
    opacity: 0.6;
  }

  .item-head{
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
  }

  .item-name{
    font-size: 16px;
    font-weight: 600;
  }

  .item-name .badge{
    display: inline-block;
    margin-left: 8px;
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-light);
    border-radius: 6px;
    padding: 2px 7px;
    vertical-align: middle;
  }

  .item-name .badge.gold{
    color: var(--gold);
    background: var(--gold-light);
  }

  .item-remove{
    background: transparent;
    color: var(--muted);
    font-size: 12px;
    padding: 4px 8px;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .item-remove:hover{
    background: var(--danger-light);
    color: var(--danger);
  }

  .item-numbers{
    display: flex;
    gap: 24px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .item-numbers .num .label{
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2px;
  }

  .item-numbers .num .value{
    font-size: 18px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .item-numbers .num.remaining .value{ color: var(--danger); }
  .item-numbers .num.paid .value{ color: var(--accent); }
  .item-numbers .num.saved .value{ color: var(--gold); }

  .item-progress{
    height: 6px;
    background: var(--line);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 14px;
  }

  .item-progress .fill{
    height: 100%;
    background: var(--accent);
    border-radius: 999px;
    transition: width 0.4s ease;
  }

  .item-progress .fill.gold{ background: var(--gold); }

  .pay-row{
    display: flex;
    gap: 10px;
  }

  .pay-row input{ flex: 1; }

  .pay-row button{
    background: var(--accent-light);
    color: var(--accent);
    white-space: nowrap;
  }

  .pay-row button.gold{
    background: var(--gold-light);
    color: var(--gold);
  }

  /* History */
  .history-toggle{
    background: transparent;
    color: var(--muted);
    font-size: 12px;
    padding: 0;
    margin-top: 12px;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .history{
    margin-top: 12px;
    border-top: 1px solid var(--line);
    padding-top: 10px;
    display: none;
  }

  .history.open{ display: block; }

  .history-item{
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    padding: 6px 0;
    color: var(--ink);
  }

  .history-item .h-date{
    color: var(--muted);
    font-size: 12px;
  }

  .history-item .h-amount{
    font-weight: 600;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  .history-item .h-amount.gold{ color: var(--gold); }

  .history-item .h-del{
    background: transparent;
    border: none;
    color: var(--muted);
    font-size: 12px;
    cursor: pointer;
    padding: 0 4px;
  }

  .history-item .h-del:hover{ color: var(--danger); }

  .empty{
    text-align: center;
    color: var(--muted);
    font-size: 14px;
    padding: 40px 20px;
    background: var(--card);
    border: 1px dashed var(--line);
    border-radius: var(--radius);
  }

  footer{
    text-align: center;
    color: var(--muted);
    font-size: 12px;
    margin-top: 30px;
  }

  /* PIN lock overlay */
  #lockScreen{
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    padding: 24px;
  }

  #lockScreen.hidden{ display: none; }

  #lockScreen h1{
    font-size: 26px;
    font-weight: 800;
    margin-bottom: 6px;
  }

  #lockScreen h1 .dot{ color: var(--accent); }

  #lockScreen p{
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 24px;
    text-align: center;
  }

  #pinInput{
    font-size: 28px;
    text-align: center;
    letter-spacing: 0.5em;
    padding: 14px;
    width: 220px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--card);
    margin-bottom: 14px;
  }

  #pinError{
    color: var(--danger);
    font-size: 13px;
    margin-bottom: 14px;
    min-height: 16px;
  }

  #pinSubmit{
    background: var(--accent);
    color: #fff;
    width: 220px;
    padding: 13px;
  }

  #pinSetupNote{
    font-size: 12px;
    color: var(--muted);
    margin-top: 18px;
    text-align: center;
    max-width: 280px;
  }

  #app{ display: none; }
  #app.unlocked{ display: block; }

</style>
</head>
<body>

<div id="lockScreen">
  <h1>Nulla<span class="dot">.</span></h1>
  <p id="lockSubtitle">Unesi PIN da pristupiš svojim podacima.</p>
  <input type="password" id="pinInput" inputmode="numeric" maxlength="6" placeholder="••••" autocomplete="off">
  <div id="pinError"></div>
  <button id="pinSubmit" type="button">Otključaj</button>
  <p id="pinSetupNote"></p>
</div>

<div id="app" class="wrap">


  <header>
    <h1>Nulla<span class="dot">.</span></h1>
    <p>Zaštićeno PIN-om — pristup imaš samo ti.</p>
  </header>

  <div class="tabs">
    <button class="tab active" data-tab="debts" onclick="switchTab('debts')">Dugovi</button>
    <button class="tab" data-tab="savings" onclick="switchTab('savings')">Štednja</button>
  </div>

  <!-- DEBTS VIEW -->
  <div class="view active" id="view-debts">

    <div class="summary">
      <div class="stat total">
        <div class="label">Ukupno preostalo</div>
        <div class="value" id="sumRemaining">0,00 €</div>
      </div>
      <div class="stat">
        <div class="label">Ukupan dug (početni)</div>
        <div class="value" id="sumOriginal">0,00 €</div>
      </div>
      <div class="stat paid">
        <div class="label">Ukupno otplaćeno</div>
        <div class="value" id="sumPaid">0,00 €</div>
      </div>
      <div class="progress-row">
        <div class="progress-bar"><div class="fill" id="sumFill" style="width:0%"></div></div>
        <div class="pct" id="sumPct">0% otplaćeno</div>
      </div>
    </div>

    <div class="add-card">
      <h2>Nova obaveza</h2>
      <div class="add-form">
        <input type="text" id="newDebtName" placeholder="Naziv (npr. Kredit Erste banka)">
        <input type="number" id="newDebtAmount" placeholder="Iznos (€)" step="0.01" min="0">
        <button class="btn-primary" onclick="addDebt()">Dodaj</button>
      </div>
    </div>

    <div class="items" id="debtList"></div>
  </div>

  <!-- SAVINGS VIEW -->
  <div class="view" id="view-savings">

    <div class="summary">
      <div class="stat savings">
        <div class="label">Ukupno odvojeno</div>
        <div class="value" id="savSaved">0,00 €</div>
      </div>
      <div class="stat">
        <div class="label">Ukupan cilj</div>
        <div class="value" id="savGoal">0,00 €</div>
      </div>
      <div class="stat">
        <div class="label">Preostalo do cilja</div>
        <div class="value" id="savRemaining">0,00 €</div>
      </div>
      <div class="progress-row">
        <div class="progress-bar"><div class="fill gold" id="savFill" style="width:0%"></div></div>
        <div class="pct" id="savPct">0% sakupljeno</div>
      </div>
    </div>

    <div class="add-card">
      <h2>Novi cilj štednje</h2>
      <div class="add-form">
        <input type="text" id="newSavName" placeholder="Naziv (npr. Rezerva za nepredviđeno)">
        <input type="number" id="newSavGoal" placeholder="Cilj (€)" step="0.01" min="0">
        <button class="btn-gold" onclick="addSaving()">Dodaj</button>
      </div>
    </div>

    <div class="items" id="savList"></div>
  </div>

  <div class="add-card" style="margin-top: 20px;">
    <h2>Backup podataka</h2>
    <p style="font-size:13px; color:var(--muted); margin-bottom:14px; line-height:1.5;">
      Sačuvaj fajl sa svim podacima na telefon — brisanje keša browsera ga ne briše.
      Po potrebi ga učitaj nazad.
    </p>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <button type="button" class="btn-primary" data-action="export-data">Sačuvaj backup (.json)</button>
      <button type="button" id="importBtn" data-action="import-data">Učitaj backup</button>
      <button type="button" data-action="change-pin" style="background:var(--line); color:var(--ink);">Promeni PIN</button>
      <input type="file" id="importFile" accept="application/json" style="display:none;">
    </div>

    <div id="backupOutput" style="display:none; margin-top:16px;">
      <p style="font-size:12px; color:var(--muted); margin-bottom:8px;">
        Ako se fajl nije sam preuzeo: kopiraj tekst ispod (dugme), nalepi ga u Notes/Beleške ili email,
        i sačuvaj kao <strong id="backupFilename"></strong>
      </p>
      <textarea id="backupTextarea" readonly style="width:100%; height:120px; font-family:monospace; font-size:11px; padding:10px; border:1px solid var(--line); border-radius:10px; background:var(--bg); resize:vertical;"></textarea>
      <button type="button" data-action="copy-backup" style="margin-top:8px; background:var(--accent-light); color:var(--accent);">Kopiraj tekst</button>
    </div>

    <div style="margin-top:16px;">
      <p style="font-size:12px; color:var(--muted); margin-bottom:8px;">
        Ili nalepi sačuvani backup tekst ovde i klikni "Učitaj iz teksta":
      </p>
      <textarea id="importTextarea" placeholder="Nalepi JSON backup ovde..." style="width:100%; height:100px; font-family:monospace; font-size:11px; padding:10px; border:1px solid var(--line); border-radius:10px; background:var(--bg); resize:vertical;"></textarea>
      <button type="button" data-action="import-from-text" style="margin-top:8px; background:var(--gold-light); color:var(--gold);">Učitaj iz teksta</button>
    </div>
  </div>

  <footer>Podaci se čuvaju u localStorage ovog browsera — preporuka je da redovno praviš backup.</footer>

</div>

<script>
const DEBTS_KEY = 'nulla_dugovi_v1';
const PIN_KEY = 'nulla_pin_v1';
const SAVINGS_KEY = 'nulla_stednja_v1';

function load(key){
  try{
    return JSON.parse(localStorage.getItem(key)) || [];
  }catch(e){ return []; }
}
function save(key, data){
  localStorage.setItem(key, JSON.stringify(data));
}

function fmt(n){
  return n.toLocaleString('sr-RS', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
}

function escapeHtml(str){
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

function switchTab(tab){
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + tab).classList.add('active');
}

/* ===================== DEBTS ===================== */

function addDebt(){
  const nameInput = document.getElementById('newDebtName');
  const amountInput = document.getElementById('newDebtAmount');
  const name = nameInput.value.trim();
  const amount = parseFloat(amountInput.value);

  if(!name || isNaN(amount) || amount <= 0){
    alert('Unesi naziv i ispravan iznos.');
    return;
  }

  const debts = load(DEBTS_KEY);
  debts.push({
    id: 'd' + Date.now().toString(),
    name: name,
    original: amount,
    paid: 0,
    history: []
  });
  save(DEBTS_KEY, debts);

  nameInput.value = '';
  amountInput.value = '';
  renderDebts();
}

function editDebt(id){
  const debts = load(DEBTS_KEY);
  const debt = debts.find(d => d.id === id);
  if(!debt) return;

  const newName = prompt('Naziv obaveze:', debt.name);
  if(newName === null) return;
  const trimmed = newName.trim();
  if(!trimmed){
    alert('Naziv ne može biti prazan.');
    return;
  }

  const newOriginal = prompt('Početni iznos (€):', debt.original);
  if(newOriginal === null){
    debt.name = trimmed;
    save(DEBTS_KEY, debts);
    renderDebts();
    return;
  }
  const amt = parseFloat(newOriginal);
  if(isNaN(amt) || amt <= 0){
    alert('Neispravan iznos — zadržan je prethodni.');
  } else {
    debt.original = amt;
  }
  debt.name = trimmed;

  save(DEBTS_KEY, debts);
  renderDebts();
}

function removeDebt(id){
  if(!confirm('Obrisati ovu obavezu i njenu istoriju?')) return;
  let debts = load(DEBTS_KEY);
  debts = debts.filter(d => d.id !== id);
  save(DEBTS_KEY, debts);
  renderDebts();
}

function addPayment(id){
  const input = document.getElementById('pay-' + id);
  const amount = parseFloat(input.value);
  if(isNaN(amount) || amount <= 0){
    alert('Unesi ispravan iznos uplate.');
    return;
  }

  const debts = load(DEBTS_KEY);
  const debt = debts.find(d => d.id === id);
  if(!debt) return;

  const remaining = debt.original - debt.paid;
  const applied = Math.min(amount, remaining);

  debt.paid += applied;
  debt.history.unshift({
    date: new Date().toISOString().slice(0,10),
    amount: applied
  });

  let updatedDebts = debts;
  if(debt.paid >= debt.original - 0.001){
    updatedDebts = debts.filter(d => d.id !== id);
    setTimeout(() => alert('"' + debt.name + '" je u potpunosti otplaćeno i uklonjeno je sa liste! 🎉'), 50);
  }

  save(DEBTS_KEY, updatedDebts);
  input.value = '';
  renderDebts();
}

function deleteDebtHistory(id, idx){
  const debts = load(DEBTS_KEY);
  const debt = debts.find(d => d.id === id);
  if(!debt) return;
  const item = debt.history[idx];
  debt.paid -= item.amount;
  debt.history.splice(idx, 1);
  save(DEBTS_KEY, debts);
  renderDebts();
}

function toggleHistory(elId){
  const el = document.getElementById(elId);
  el.classList.toggle('open');
}

function renderDebts(){
  const debts = load(DEBTS_KEY);
  const list = document.getElementById('debtList');
  list.innerHTML = '';

  let totalOriginal = 0;
  let totalPaid = 0;

  if(debts.length === 0){
    list.innerHTML = '<div class="empty">Nema unesenih obaveza. Dodaj prvu iznad.</div>';
  }

  debts.forEach(debt => {
    totalOriginal += debt.original;
    totalPaid += debt.paid;

    const remaining = Math.max(debt.original - debt.paid, 0);
    const pct = debt.original > 0 ? Math.min((debt.paid / debt.original) * 100, 100) : 0;
    const settled = remaining <= 0.001;

    const card = document.createElement('div');
    card.className = 'item-card' + (settled ? ' settled' : '');

    let html = '';
    html += '<div class="item-head">';
    html += '<div class="item-name">' + escapeHtml(debt.name);
    if(settled) html += ' <span class="badge">OTPLAĆENO</span>';
    html += '</div>';
    html += '<div style="display:flex;gap:6px;flex-shrink:0;">';
    html += '<button type="button" class="item-remove" data-action="edit-debt" data-id="' + debt.id + '">Izmeni</button>';
    html += '<button type="button" class="item-remove" data-action="remove-debt" data-id="' + debt.id + '">Obriši</button>';
    html += '</div>';
    html += '</div>';

    html += '<div class="item-numbers">';
    html += '<div class="num remaining"><div class="label">Preostalo</div><div class="value">' + fmt(remaining) + '</div></div>';
    html += '<div class="num paid"><div class="label">Otplaćeno</div><div class="value">' + fmt(debt.paid) + '</div></div>';
    html += '<div class="num"><div class="label">Početni iznos</div><div class="value">' + fmt(debt.original) + '</div></div>';
    html += '</div>';

    html += '<div class="item-progress"><div class="fill" style="width:' + pct + '%"></div></div>';

    if(!settled){
      html += '<div class="pay-row">';
      html += '<input type="number" id="pay-' + debt.id + '" placeholder="Iznos uplate (€)" step="0.01" min="0">';
      html += '<button type="button" data-action="pay-debt" data-id="' + debt.id + '">Upiši uplatu</button>';
      html += '</div>';
    }

    if(debt.history.length > 0){
      html += '<button type="button" class="history-toggle" data-action="toggle-hist" data-target="hist-' + debt.id + '">Istorija uplata (' + debt.history.length + ')</button>';
      html += '<div class="history" id="hist-' + debt.id + '">';
      debt.history.forEach((h, idx) => {
        html += '<div class="history-item">';
        html += '<span class="h-date">' + h.date + '</span>';
        html += '<span class="h-amount">+' + fmt(h.amount) + '</span>';
        html += '<button type="button" class="h-del" data-action="del-debt-hist" data-id="' + debt.id + '" data-idx="' + idx + '">ukloni</button>';
        html += '</div>';
      });
      html += '</div>';
    }

    card.innerHTML = html;
    list.appendChild(card);
  });

  const totalRemaining = totalOriginal - totalPaid;
  const overallPct = totalOriginal > 0 ? (totalPaid / totalOriginal) * 100 : 0;

  document.getElementById('sumRemaining').textContent = fmt(totalRemaining);
  document.getElementById('sumOriginal').textContent = fmt(totalOriginal);
  document.getElementById('sumPaid').textContent = fmt(totalPaid);
  document.getElementById('sumFill').style.width = overallPct + '%';
  document.getElementById('sumPct').textContent = overallPct.toFixed(1) + '% otplaćeno';
}

/* ===================== SAVINGS ===================== */

function addSaving(){
  const nameInput = document.getElementById('newSavName');
  const goalInput = document.getElementById('newSavGoal');
  const name = nameInput.value.trim();
  const goal = parseFloat(goalInput.value);

  if(!name || isNaN(goal) || goal <= 0){
    alert('Unesi naziv i ispravan cilj.');
    return;
  }

  const savs = load(SAVINGS_KEY);
  savs.push({
    id: 's' + Date.now().toString(),
    name: name,
    goal: goal,
    saved: 0,
    history: []
  });
  save(SAVINGS_KEY, savs);

  nameInput.value = '';
  goalInput.value = '';
  renderSavings();
}

function removeSaving(id){
  if(!confirm('Obrisati ovaj cilj i njegovu istoriju?')) return;
  let savs = load(SAVINGS_KEY);
  savs = savs.filter(s => s.id !== id);
  save(SAVINGS_KEY, savs);
  renderSavings();
}

function addSavingDeposit(id){
  const input = document.getElementById('sav-' + id);
  const amount = parseFloat(input.value);
  if(isNaN(amount) || amount <= 0){
    alert('Unesi ispravan iznos.');
    return;
  }

  const savs = load(SAVINGS_KEY);
  const s = savs.find(x => x.id === id);
  if(!s) return;

  s.saved += amount;
  s.history.unshift({
    date: new Date().toISOString().slice(0,10),
    amount: amount
  });

  save(SAVINGS_KEY, savs);
  input.value = '';
  renderSavings();
}

function deleteSavingHistory(id, idx){
  const savs = load(SAVINGS_KEY);
  const s = savs.find(x => x.id === id);
  if(!s) return;
  const item = s.history[idx];
  s.saved -= item.amount;
  s.history.splice(idx, 1);
  save(SAVINGS_KEY, savs);
  renderSavings();
}

function renderSavings(){
  const savs = load(SAVINGS_KEY);
  const list = document.getElementById('savList');
  list.innerHTML = '';

  let totalGoal = 0;
  let totalSaved = 0;

  if(savs.length === 0){
    list.innerHTML = '<div class="empty">Nema unesenih ciljeva štednje. Dodaj prvi iznad.</div>';
  }

  savs.forEach(s => {
    totalGoal += s.goal;
    totalSaved += s.saved;

    const remaining = Math.max(s.goal - s.saved, 0);
    const pct = s.goal > 0 ? Math.min((s.saved / s.goal) * 100, 100) : 0;
    const reached = remaining <= 0.001;

    const card = document.createElement('div');
    card.className = 'item-card' + (reached ? ' settled' : '');

    let html = '';
    html += '<div class="item-head">';
    html += '<div class="item-name">' + escapeHtml(s.name);
    if(reached) html += ' <span class="badge gold">CILJ DOSTIGNUT</span>';
    html += '</div>';
    html += '<button type="button" class="item-remove" data-action="remove-saving" data-id="' + s.id + '">Obriši</button>';
    html += '</div>';

    html += '<div class="item-numbers">';
    html += '<div class="num saved"><div class="label">Odvojeno</div><div class="value">' + fmt(s.saved) + '</div></div>';
    html += '<div class="num remaining"><div class="label">Preostalo do cilja</div><div class="value">' + fmt(remaining) + '</div></div>';
    html += '<div class="num"><div class="label">Cilj</div><div class="value">' + fmt(s.goal) + '</div></div>';
    html += '</div>';

    html += '<div class="item-progress"><div class="fill gold" style="width:' + pct + '%"></div></div>';

    html += '<div class="pay-row">';
    html += '<input type="number" id="sav-' + s.id + '" placeholder="Iznos uplate (€)" step="0.01" min="0">';
    html += '<button type="button" class="gold" data-action="pay-saving" data-id="' + s.id + '">Upiši uplatu</button>';
    html += '</div>';

    if(s.history.length > 0){
      html += '<button type="button" class="history-toggle" data-action="toggle-hist" data-target="histsav-' + s.id + '">Istorija uplata (' + s.history.length + ')</button>';
      html += '<div class="history" id="histsav-' + s.id + '">';
      s.history.forEach((h, idx) => {
        html += '<div class="history-item">';
        html += '<span class="h-date">' + h.date + '</span>';
        html += '<span class="h-amount gold">+' + fmt(h.amount) + '</span>';
        html += '<button type="button" class="h-del" data-action="del-saving-hist" data-id="' + s.id + '" data-idx="' + idx + '">ukloni</button>';
        html += '</div>';
      });
      html += '</div>';
    }

    card.innerHTML = html;
    list.appendChild(card);
  });

  const totalRemaining = Math.max(totalGoal - totalSaved, 0);
  const overallPct = totalGoal > 0 ? Math.min((totalSaved / totalGoal) * 100, 100) : 0;

  document.getElementById('savSaved').textContent = fmt(totalSaved);
  document.getElementById('savGoal').textContent = fmt(totalGoal);
  document.getElementById('savRemaining').textContent = fmt(totalRemaining);
  document.getElementById('savFill').style.width = overallPct + '%';
  document.getElementById('savPct').textContent = overallPct.toFixed(1) + '% sakupljeno';
}

/* ===================== BACKUP ===================== */

function exportData(){
  const data = {
    app: 'Nulla',
    exportedAt: new Date().toISOString(),
    debts: load(DEBTS_KEY),
    savings: load(SAVINGS_KEY)
  };
  const json = JSON.stringify(data, null, 2);
  const dateStr = new Date().toISOString().slice(0,10);
  const filename = 'nulla-backup-' + dateStr + '.json';

  try{
    const blob = new Blob([json], {type: 'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }catch(err){
    // fallback: ne radi nista, idemo na text prikaz ispod
  }

  // Fallback / dodatna opcija za mobilne browsere koji blokiraju download na file://
  showBackupText(json, filename);
}

function showBackupText(json, filename){
  const box = document.getElementById('backupOutput');
  document.getElementById('backupFilename').textContent = filename;
  document.getElementById('backupTextarea').value = json;
  box.style.display = 'block';
  box.scrollIntoView({behavior: 'smooth', block: 'center'});
}

function copyBackupText(){
  const ta = document.getElementById('backupTextarea');
  ta.select();
  ta.setSelectionRange(0, 999999);
  try{
    document.execCommand('copy');
    alert('Tekst je kopiran. Nalepi ga (paste) u Notes/Beleške i sačuvaj kao .txt ili .json fajl.');
  }catch(err){
    alert('Selektuj tekst i kopiraj rucno (dugme za kopiranje nije podrzano).');
  }
}

function importData(){
  document.getElementById('importFile').click();
}

function handleImportFile(file){
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    let data;
    try{
      data = JSON.parse(e.target.result);
    }catch(err){
      alert('Fajl nije ispravan JSON backup.');
      return;
    }
    applyImportedData(data);
  };
  reader.readAsText(file);
}

function applyImportedData(data){
  if(!data.debts && !data.savings){
    alert('Ovo ne izgleda kao Nulla backup fajl.');
    return;
  }

  const existingDebts = load(DEBTS_KEY);
  const existingSavings = load(SAVINGS_KEY);
  const hasExisting = existingDebts.length > 0 || existingSavings.length > 0;

  let mode = 'replace';
  if(hasExisting){
    mode = confirm('Već postoje podaci u aplikaciji.\n\nOK = zameni sve postojeće podatke učitanim backupom\nOtkaži = dodaj učitane podatke pored postojećih')
      ? 'replace' : 'merge';
  }

  if(mode === 'replace'){
    save(DEBTS_KEY, data.debts || []);
    save(SAVINGS_KEY, data.savings || []);
  } else {
    save(DEBTS_KEY, existingDebts.concat(data.debts || []));
    save(SAVINGS_KEY, existingSavings.concat(data.savings || []));
  }

  renderDebts();
  renderSavings();
  alert('Backup učitan.');
}

function importFromText(){
  const text = document.getElementById('importTextarea').value.trim();
  if(!text){
    alert('Nalepi backup tekst pre učitavanja.');
    return;
  }
  let data;
  try{
    data = JSON.parse(text);
  }catch(err){
    alert('Tekst nije ispravan JSON backup.');
    return;
  }
  applyImportedData(data);
}

document.getElementById('importFile').addEventListener('change', function(e){
  handleImportFile(e.target.files[0]);
  e.target.value = '';
});



document.addEventListener('click', function(e){
  const btn = e.target.closest('button[data-action]');
  if(!btn) return;
  const action = btn.dataset.action;
  const id = btn.dataset.id;

  switch(action){
    case 'edit-debt': editDebt(id); break;
    case 'remove-debt': removeDebt(id); break;
    case 'pay-debt': addPayment(id); break;
    case 'del-debt-hist': deleteDebtHistory(id, parseInt(btn.dataset.idx)); break;
    case 'remove-saving': removeSaving(id); break;
    case 'pay-saving': addSavingDeposit(id); break;
    case 'del-saving-hist': deleteSavingHistory(id, parseInt(btn.dataset.idx)); break;
    case 'toggle-hist': toggleHistory(btn.dataset.target); break;
    case 'export-data': exportData(); break;
    case 'import-data': importData(); break;
    case 'copy-backup': copyBackupText(); break;
    case 'import-from-text': importFromText(); break;
    case 'change-pin': changePin(); break;
  }
});

function changePin(){
  const current = localStorage.getItem(PIN_KEY);
  const old = prompt('Unesi trenutni PIN:');
  if(old === null) return;
  if(old !== current){
    alert('Pogrešan PIN.');
    return;
  }
  const next = prompt('Unesi novi PIN (4-6 cifara):');
  if(next === null) return;
  if(!/^\d{4,6}$/.test(next)){
    alert('PIN mora imati 4 do 6 cifara.');
    return;
  }
  localStorage.setItem(PIN_KEY, next);
  alert('PIN je promenjen.');
}



function initLock(){
  const storedPin = localStorage.getItem(PIN_KEY);
  const subtitle = document.getElementById('lockSubtitle');
  const note = document.getElementById('pinSetupNote');
  const input = document.getElementById('pinInput');
  const submit = document.getElementById('pinSubmit');
  const errorEl = document.getElementById('pinError');

  if(!storedPin){
    subtitle.textContent = 'Postavi PIN (4-6 cifara) koji će štititi tvoje podatke.';
    note.textContent = 'Zapamti ovaj PIN — ako ga zaboraviš, podatke možeš resetovati samo brisanjem svih podataka stranice (i tako izgubiti unose).';
  } else {
    subtitle.textContent = 'Unesi PIN da pristupiš svojim podacima.';
    note.textContent = '';
  }

  function tryUnlock(){
    const val = input.value.trim();
    const current = localStorage.getItem(PIN_KEY);

    if(!current){
      if(val.length < 4 || val.length > 6 || !/^\d+$/.test(val)){
        errorEl.textContent = 'PIN mora imati 4 do 6 cifara.';
        return;
      }
      localStorage.setItem(PIN_KEY, val);
      unlock();
      return;
    }

    if(val === current){
      unlock();
    } else {
      errorEl.textContent = 'Pogrešan PIN. Pokušaj ponovo.';
      input.value = '';
      input.focus();
    }
  }

  function unlock(){
    document.getElementById('lockScreen').classList.add('hidden');
    const app = document.getElementById('app');
    app.classList.add('unlocked');
    renderDebts();
    renderSavings();
  }

  submit.addEventListener('click', tryUnlock);
  input.addEventListener('keydown', function(e){
    if(e.key === 'Enter') tryUnlock();
  });
  input.focus();
}

initLock();

</script>

